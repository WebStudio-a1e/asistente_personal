# ─────────────────────────────────────────────────────────────
# LLMs por agente — intercambiables sin tocar código
# Valores válidos: claude-sonnet-4-6 | gpt-4o | gemini-2.0-flash | deepseek-chat
# ─────────────────────────────────────────────────────────────
LLM_ORCHESTRATOR=claude-sonnet-4-6
LLM_TASKS=gpt-4o
LLM_IDEAS=claude-sonnet-4-6
LLM_AGENDA=gemini-2.0-flash
LLM_ACCOUNTING=gpt-4o
LLM_REPORTING=claude-sonnet-4-6

# ─────────────────────────────────────────────────────────────
# API Keys — LLM providers
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ─────────────────────────────────────────────────────────────
# Twilio — WhatsApp
# ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número Twilio (sandbox: whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Tu número personal de WhatsApp
TWILIO_WHATSAPP_TO=whatsapp:+598XXXXXXXXX

# ─────────────────────────────────────────────────────────────
# Google APIs
# ─────────────────────────────────────────────────────────────
# Ruta al JSON de la service account (archivo gitignored)
GOOGLE_CREDENTIALS_PATH=credentials/google_credentials.json
# Google Sheets — tareas (ID de la URL del archivo)
GOOGLE_SHEETS_TASKS_ID=
# Google Sheets — contabilidad (archivo separado)
GOOGLE_SHEETS_ACCOUNTING_ID=
# Google Docs — ideas (documento maestro)
GOOGLE_DOCS_IDEAS_ID=
# Google Calendar — agenda personal
GOOGLE_CALENDAR_ID=
# Google Drive — carpeta raíz (opcional)
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
TIMEZONE=America/Montevideo
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# SQLite — checkpointer LangGraph + tablas operativas
# ─────────────────────────────────────────────────────────────
SQLITE_DB_PATH=data/asistente_personal.db

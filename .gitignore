# ─── Entorno ───────────────────────────────────
.env
.env.*
!.env.example

# ─── Credenciales (NUNCA commitear) ────────────
credentials/*
!credentials/.gitkeep

# ─── Base de datos local ────────────────────────
data/*
!data/.gitkeep

# ─── Python ─────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ─── Testing ────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ─── Linting ────────────────────────────────────
.ruff_cache/

# ─── Entornos virtuales ─────────────────────────
.venv/
venv/
env/

# ─── IDE ────────────────────────────────────────
.vscode/
.idea/

# ─── Claude Code (personal, no del equipo) ──────
.claude/settings.local.json

# ─── Infraestructura local — SSL inspection ─────
# CA del proxy corporativo/antivirus del host. Solo necesaria en dev local
# con SSL inspection. Se inyecta via BuildKit secret, nunca se commitea.
proxy-ca.pem
# Override local de docker-compose (activa el secret en dev con SSL inspection).
# El ejemplo versionado es docker-compose.override.example.yml.
docker-compose.override.yml

# ─── OS ─────────────────────────────────────────
.DS_Store
Thumbs.db
